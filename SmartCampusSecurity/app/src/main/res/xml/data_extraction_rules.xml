<?xml version="1.0" encoding="utf-8"?>
<!-- Excludes ALL app data from Android Auto Backup and device-to-device transfer.
     Required for OWASP MASVS compliance: attendance/biometric data must never
     leave the device via backup channels. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
